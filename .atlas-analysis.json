  "keyFeatures": [
    "Authentication & Authorization with API key management",
    "OAuth 2.0/2.1 support with mutual TLS (mTLS)",
    "Input/Output guardrails (PII, toxicity, injection attacks, policy violations)",
    "Dynamic tool discovery from MCP servers",
    "Multi-level caching (local & external Redis/KeyDB)",
    "OpenTelemetry observability with Prometheus & Grafana",
    "Plugin architecture for auth, guardrails, and telemetry",
    "REST API and CLI for configuration management",
    "Support for multiple MCP clients (Claude, Cursor, Copilot, LangChain)"
  ],
  "publicApiSurface": [
    "secure-mcp-gateway (CLI entry point)",
    "Gateway Server (FastMCP on :8000/mcp/)",
    "REST API Server (FastAPI on :8001)",
    "enkrypt_list_all_servers - List configured MCP servers",
    "enkrypt_get_server_info - Get server details",
    "enkrypt_discover_all_tools - Discover tools from servers",
    "enkrypt_secure_call_tools - Execute tools with guardrails",
    "enkrypt_get_cache_status - Cache statistics",
    "enkrypt_clear_cache - Clear cache entries",
    "enkrypt_get_timeout_metrics - Timeout metrics",
    "POST /api/v1/configs - Create configuration",
    "GET /api/v1/configs - List configurations",
    "POST /api/v1/projects - Create project",
    "POST /api/v1/users - Create user",
    "POST /api/v1/api-keys - Generate API key",
